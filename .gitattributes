# Нормализация line endings: в репозитории всегда LF, при checkout на Windows — CRLF.
# Без этого git diff показывает "фантомные" изменения во всех файлах.

* text=auto eol=lf

# Бинарные форматы — не трогать
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.session binary
*.db binary

# Windows-специфичные файлы оставляем CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
